#include <iostream>
#include <Windows.h>
int main()
{
    srand(time(NULL));
    setlocale(LC_ALL, "ru");

    HANDLE mutex = CreateMutexA(NULL, FALSE, "PrinterMutex");
    if (mutex == NULL) {
        return GetLastError();
    }

    std::cout << "Принтер активен" << std::endl;
    while (true) {
        DWORD wait = WaitForSingleObject(mutex, 600000);
        if (wait == WAIT_OBJECT_0) {
            std::cout << "Печать" << std::endl;
            int time = rand() % 15;
            if (time >= 10) {
                std::cout << "Ошибка печати" << std::endl;
                break;
            }
            else {
                Sleep(time * 1000);
                std::cout << "Готово" << std::endl;
            }
            ReleaseMutex(mutex);
        }
        else {
            std::cout << "Принтер выключается" << std::endl;
            break;
        } 
    }

    CloseHandle(mutex);
    return 0;

}
