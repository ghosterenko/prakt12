#include <iostream>
#include <Windows.h>
int main()
{
    srand(time(NULL));
    setlocale(LC_ALL, "ru");

    HANDLE mutex = CreateMutex(NULL, FALSE, L"PrinterMutex");
    if (mutex == NULL) return GetLastError();
    std::cin.get();

    
    while (true)
    {
        std::cout << "Ожидание" << std::endl;
        DWORD wait = WaitForSingleObject(mutex, 3000);
        if (wait == WAIT_OBJECT_0) {

            std::cout << "Печать" << std::endl;
            int time = rand() % 15;
            Sleep(1000);
            if (time > 10) {
                std::cout << "Ошибка печати" << std::endl;
            }
            else {
                std::cout << "Печатает" << std::endl;
            }
            Sleep(time * 1000);
            ReleaseMutex(mutex);
            std::cout << "Готово" << std::endl;

            std::cout<<std::endl;
        }
    }
    CloseHandle(mutex);
    return 0;
}
