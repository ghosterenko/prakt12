#include <iostream>
#include <Windows.h>
int main()
{
    srand(time(NULL));
    setlocale(LC_ALL, "ru");

    HANDLE mutex = CreateMutexA(NULL, FALSE, "PrinterMutex");
    if (mutex == NULL) return GetLastError();
    while (true) {
        DWORD wait = WaitForSingleObject(mutex, INFINITE);
        if (wait == WAIT_OBJECT_0) {
            std::cout << "Печать" << std::endl;
            int time = rand() % 15;
            if (time >= 10) {
                std::cout << "Ошибка печати" << std::endl;
                break;
            }
            else {
                Sleep(time * 1000);
            }
            ReleaseMutex(mutex);
            std::cout << "Готово" << std::endl;
        }
    }
    WaitForSingleObject(mutex, INFINITE);
    CloseHandle(mutex);
    return 0;

}
